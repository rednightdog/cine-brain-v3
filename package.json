{
  "name": "cine-brain-pro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:seed:catalog": "tsx prisma/seed-catalog.ts",
    "db:studio": "prisma studio",
    "db:health:catalog": "tsx scripts/catalog-health-report.ts",
    "db:fill:gaps": "tsx scripts/fill-catalog-gaps.ts",
    "db:priority:cam-lens": "tsx scripts/export-priority-updates.ts --limit 20",
    "db:validate:contract": "tsx scripts/validate-catalog-contract.ts",
    "db:validate:contract:cam-lens": "tsx scripts/validate-catalog-contract.ts --cam-lens-only",
    "db:validate:contract:cam-lens:enforce": "tsx scripts/validate-catalog-contract.ts --cam-lens-only --enforce-pending",
    "db:import:csv": "tsx scripts/import-inventory-csv.ts",
    "db:import:csv:preview": "tsx scripts/import-inventory-csv.ts --file ./imports/my-inventory.csv --dry-run --only-cam-lens",
    "db:import:csv:template:dry": "tsx scripts/import-inventory-csv.ts --file ./imports/inventory-template.csv --dry-run",
    "db:import:csv:template:tr:dry": "tsx scripts/import-inventory-csv.ts --file ./imports/inventory-template-tr.csv --dry-run",
    "db:export:csv": "tsx scripts/export-inventory-csv.ts --file ./imports/my-inventory.csv --only-cam-lens --editable",
    "db:export:csv:full": "tsx scripts/export-inventory-csv.ts --file ./imports/my-inventory-full.csv --only-cam-lens",
    "db:export:csv:all": "tsx scripts/export-inventory-csv.ts --file ./imports/my-inventory-all.csv --include-pending --include-private",
    "db:backups:list": "tsx scripts/list-inventory-backups.ts",
    "db:sync:inventory": "tsx scripts/sync-inventory-cycle.ts --file ./imports/my-inventory.csv --only-cam-lens",
    "db:sync:inventory:dry": "tsx scripts/sync-inventory-cycle.ts --file ./imports/my-inventory.csv --only-cam-lens --dry-run-only",
    "db:sync:inventory:safe:dry": "tsx scripts/sync-inventory-cycle.ts --file ./imports/my-inventory.csv --only-cam-lens --dry-run-only --max-total-changes 120 --max-inserts 40 --max-change-ratio 0.35",
    "db:restore:latest": "tsx scripts/restore-inventory-backup.ts --only-cam-lens",
    "db:restore:latest:dry": "tsx scripts/restore-inventory-backup.ts --only-cam-lens --dry-run-only",
    "db:restore:previous": "tsx scripts/restore-inventory-backup.ts --only-cam-lens --offset 1",
    "db:restore:previous:dry": "tsx scripts/restore-inventory-backup.ts --only-cam-lens --dry-run-only --offset 1",
    "db:restore:latest:safe:dry": "tsx scripts/restore-inventory-backup.ts --only-cam-lens --dry-run-only --max-total-changes 120 --max-inserts 40 --max-change-ratio 0.35",
    "db:pipeline:quality": "npm run db:fill:gaps && npm run db:validate:contract:cam-lens"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "blob-stream": "^0.1.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "google-search-results-nodejs": "^2.1.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "openai": "^6.17.0",
    "pdfkit": "^0.17.2",
    "prisma": "^6.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/blob-stream": "^0.1.33",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
